# Snap Camera Kit Configuration
# Get your API token from: https://camera-kit.snapchat.com/
VITE_SNAP_API_TOKEN=your_snap_api_token_here

# Group ID containing your lenses
VITE_SNAP_GROUP_ID=your_snap_group_id_here

# Snap Lens IDs for different styles
VITE_SNAP_LENS_NATURAL=your_natural_lens_id_here
VITE_SNAP_LENS_CATEYE=your_cateye_lens_id_here
VITE_SNAP_LENS_DRAMATIC=your_dramatic_lens_id_here

# Backend API URL
# Local development: http://localhost:5000
VITE_API_URL=http://localhost:5000

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
